{
  "embedder": {
    "client_class": "GoogleGenAIClient",
    "initialize_kwargs": {
      "api_key": "${GOOGLE_API_KEY}"
    },
    "model_kwargs": {
      "model": "models/text-embedding-004"
    },
    "batch_size": 10
  },
  "embedder_ollama": {
    "client_class": "OllamaClient",
    "model_kwargs": {
      "model": "nomic-embed-text"
    }
  },
  "retriever": {
    "top_k": 20
  },
  "text_splitter": {
    "split_by": "word",
    "chunk_size": 200,
    "chunk_overlap": 50
  }
}